{
  "name": "b-gym-api",
  "version": "1.0.0",
  "description": "API REST em JavaScript com Express e banco em memoria para o app B-Gym.",
  "main": "src/server.js",
  "scripts": {
    "build": "vite build",
    "dev:client": "vite",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "npm run test:api",
    "test:api": "mocha --config .mocharc.json",
    "pretest:web": "npm run build",
    "test:web": "start-server-and-test \"node scripts/start-web-test-server.js\" http://127.0.0.1:3000 \"cypress run --browser electron\"",
    "test:web:open": "cypress open"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "cypress": "^15.13.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "start-server-and-test": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
