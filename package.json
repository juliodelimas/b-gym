{
  "name": "b-gym",
  "version": "1.0.0",
  "description": "Projeto full stack do B-Gym com API Express, aplicacao Web React e automacao de testes API e Web.",
  "main": "src/server.js",
  "scripts": {
    "build": "npm run build:web",
    "build:web": "vite build",
    "start": "npm run start:api",
    "start:api": "node src/server.js",
    "dev": "npm run dev:api",
    "dev:api": "node --watch src/server.js",
    "dev:web": "vite",
    "test": "npm run test:all",
    "test:all": "npm run test:api && npm run test:web",
    "test:api": "mocha --config .mocharc.json",
    "test:web:prepare": "npm run build:web",
    "test:web": "npm run test:web:prepare && start-server-and-test \"node scripts/start-web-test-server.js\" http://127.0.0.1:3000 \"cypress run --browser electron\"",
    "test:web:open": "cypress open"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.8"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "cypress": "^15.13.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "start-server-and-test": "^3.0.0",
    "supertest": "^7.2.2"
  }
}
